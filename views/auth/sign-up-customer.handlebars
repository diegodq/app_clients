<!--begin::Main-->
<!--begin::Root-->
<div class='d-flex flex-column flex-root'>
  <!--begin::Authentication - Sign-up -->
  <div
    class='d-flex flex-column flex-column-fluid bgi-position-y-bottom position-x-center bgi-no-repeat bgi-size-contain bgi-attachment-fixed'>
    <!--begin::Content-->
    <div class='d-flex flex-center flex-column flex-column-fluid p-10 pb-lg-20'>
      <!--begin::Logo-->
      <a href='/' class='mb-12'>
        <img alt='Logo' src='/assets/media/logos/logo.png' class='h-75px' />
      </a>
      <!--end::Logo-->
      <!--begin::Wrapper-->
      <div class='w-lg-600px bg-body rounded shadow-sm p-10 p-lg-15 mx-auto'>
        <!--begin::Form-->
        <form class='form w-100' id='customer_form'>
          <!--begin::Heading-->
          <div class='mb-10 text-center'>
            <!--begin::Title-->
            <h1 class='text-dark mb-3'>Cadastre-se!</h1>
            <!--end::Title-->
            <!--begin::Link-->
            <div class='text-gray-400 fw-bold fs-4'>Já tem uma conta?
              <a id="link-make-login" class='link-primary fw-bolder cursor-pointer'>Acesse aqui</a>
            </div>
            <!--end::Link-->
          </div>
          <!--end::Heading-->
          <!--begin::Separator-->
          <div id="error-area" class="text-center text-danger mb-4"></div>
          <div class='d-flex align-items-center mb-10'>
            <div class='border-bottom border-gray-300 mw-50 w-100'></div>
            <div class='border-bottom border-gray-300 mw-50 w-100'></div>
          </div>
          <div class='text-gray-400 fw-bold fs-4 mb-5 text-center'>Dados Pessoais</div>
          <!--end::Separator-->
          <!--begin::Input group-->
          <div class='row fv-row'>
            <!--begin::Col-->
            <div class='col-xl-6 mb-2'>
              <label class='form-label fw-bolder text-dark fs-6 required'>Seu
                nome
              </label>
              <input class='form-control form-control-lg form-control-solid' type='text' placeholder=''
                name='first_name' autocomplete='off' />
            </div>
            <!--end::Col-->
            <!--begin::Col-->
            <div class='col-xl-6'>
              <label class='form-label fw-bolder text-dark fs-6 required'>Sobrenome </label>
              <input class='form-control form-control-lg form-control-solid' type='text' placeholder='' name='surname'
                autocomplete='off' />
            </div>
            <!--end::Col-->
          </div>
          <div class='row fv-row mb-2'>
            <!--begin::Col-->
            <div class='col-xl-6'>
              <label class='form-label fw-bolder text-dark fs-6 required'>Cargo
                / Profissão</label>
              <input class='form-control form-control-lg form-control-solid' type='text' placeholder='' name='position'
                autocomplete='off' />
            </div>
            <!--end::Col-->
            <!--begin::Col-->
            <div class='col-xl-6'>
              <label class='form-label fw-bolder text-dark fs-6'>Celular
              </label>
              <input class='form-control form-control-lg form-control-solid' type='text' placeholder='(00) 00000-0000'
                name='phone' autocomplete='off' />
            </div>
            <!--end::Col-->
          </div>
          <!--end::Input group-->
          <!--begin::Input group-->
          <div class='fv-row mb-7'>
            <label class='form-label fw-bolder text-dark fs-6 required'>E-mail</label>
            <input class='form-control form-control-lg form-control-solid' type='email' placeholder='nome@email.com.br'
              name='email' autocomplete='off' />
          </div>
          <!--end::Input group-->
          <!--begin::Input group-->
          <div class='mb-10 fv-row' data-kt-password-meter='true'>
            <!--begin::Wrapper-->
            <div class='mb-1'>
              <!--begin::Label-->
              <label class='form-label fw-bolder text-dark fs-6 required'>Crie
                sua senha
              </label>
              <!--end::Label-->
              <!--begin::Input wrapper-->
              <div class='position-relative mb-3'>
                <input class='form-control form-control-lg form-control-solid' type='password' id="password"
                  name='password' autocomplete='off' />
                <span class='btn btn-sm btn-icon position-absolute translate-middle top-50 end-0 me-n2'
                  data-kt-password-meter-control='visibility'>
                  <i id="icon-eye-open" class='bi bi-eye-slash fs-2'></i>
                  <i id="icon-eye-closed" class='bi bi-eye fs-2 d-none'></i>
                </span>
              </div>
              <div class="password-error-label error-label"></div>
              <!--end::Input wrapper-->
            </div>
            <!--end::Wrapper-->
            <!--begin::Hint-->
            <div class='text-muted'>A senha deve conter 8 ou mais caracteres e
              composta por letras, números e símbolos.</div>
            <!--end::Hint-->
          </div>
          <!--end::Input group=-->
          <!--begin::Input group-->
          <div class='fv-row mb-5'>
            <label class='form-label fw-bolder text-dark fs-6 required'>Confirme
              sua senha
            </label>

            <div class='position-relative mb-3'>
               <input class='form-control form-control-lg form-control-solid' type='password' placeholder=''
              name='confirm_password' autocomplete='off' />
                <span class='btn btn-sm btn-icon position-absolute translate-middle top-50 end-0 me-n2'
                  data-kt-password-meter-control='visibility'>
                  <i id="icon-eye-open2" class='bi bi-eye-slash fs-2'></i>
                  <i id="icon-eye-closed2" class='bi bi-eye fs-2 d-none'></i>
                </span>
              </div>

          </div>
          <!--end::Input group-->
          <div class="fv-row mb-10">
            <label class="form-check form-check-custom form-check-solid form-check-inline">
              <input class="form-check-input" type="checkbox" name="accept_terms" value="1" />
              <span class="form-check-label fw-bold text-gray-700 fs-6">Eu aceito os
                <a href="#" class="ms-1 link-primary">Termos de uso</a>.</span>
              <div id="accept-terms-error" class="text-danger"></div>
            </label>
          </div>
          <!--end::Input group-->
          <!--begin::Actions-->
          <div class='text-center'>
            <button type='submit' id='button_sign_up_customer' class='btn btn-lg btn-primary'>
              <span class='indicator-label'> CADASTRAR </span>
              <span class='indicator-progress'>
                <span class='spinner-border spinner-border-sm align-middle ms-2'></span></span>
            </button>
          </div>
          <!--end::Actions-->
        </form>
        <!--end::Form-->
      </div>
      <!--end::Wrapper-->
    </div>
    <!--end::Content-->
  </div>
  <!--end::Authentication - Sign-up-->
</div>
<!--end::Root-->
<!--end::Main-->
<div id="spinner-overlay">
  <div class="spinner-border text-danger text-f05742" role="status">
    <span class="visually-hidden">Carregando...</span>
  </div>
</div>


