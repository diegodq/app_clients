		<!--end::Container-->


	</div>
	<!--end::Post-->

	<div id="style_container" class="container-xxl mt-6">
		<div class="card-header border-0 pt-6">
			<!--begin::Card title-->
			<h1 class="text-muted fw-bolder mt-5 mb-5 ml-2"> Estilizar Pesquisa </h1>
			<h3 class="text-muted fw-bolder mt-5 mb-5 ml-2"> Configure suas preferências de cores e personalização da
				sua pesquisa.</h3>

			<div class="card-body pt-0 mt-5">
				<div class="row align-items-center justify-content-center">
					<!--begin::Col-->
					<div class="col-lg-4">
						<h3 class="text-muted fw-bolder mt-5 mb-5 ml-2 text-center"> Sua Marca</h3>
						<h5 class="text-muted fw-bolder mt-5 mb-5 ml-2 text-center"> Aqui coloque sua marca. Ela será
							exibida no cabeçalho da
							pesquisa.</h5>
						<form id="form-brand">
							<!--begin::Image input-->
							<div class="d-flex flex-column image-input image-input-outline align-items-center mt-6">
								<!--begin::Preview existing logo-->
								<div class="image-container">
									<img id="brand-company" class="image-input-wrapper brand-image">
								</div>
								<div class="input-group custom-input-group d-flex justify-content-center mt-6">
									<label for="brand" class="btn btn-primary" id="button-send-logo-brand">
										<i class="bi bi-file-earmark-arrow-up bi-lg"></i>
										Inserir Marca
									</label>
									<button class="btn btn-light btn-active-light-primary justify-content-center hidden"
										id="edit-logo-brand">Editar</button>
								</div>
								<input type="file" id="brand" class="form-control custom-input" style="display: none;">
							</div>
							<div class="form-text mt-2 text-center">Formatos aceitos: png ou jpg até 1 mb</div>
							<div id="error-brand-size" class="text-danger"></div>
						</form>
					</div>
					<div class="col-lg-4 d-flex align-items-center">
						<div class="flex-column">
							<h3 class="text-muted fw-bolder mt-5 mb-5 ml-2 text-center"> Cor de Fundo (Background)</h3>
							<h5 class="text-muted fw-bolder mt-5 mb-5 ml-2 text-center"> Escolha a cor que deseja para o
								fundo da pesquisa.</h5>
							<div class="picker-container">
								<div class="label">COR</div>
								<div id="picker"></div>
								<div class="label">LUMINOSIDADE</div>
							</div>
						</div>
						<div class="flex-row">
							<label class="label">Cor Escolhida:</label>
							<div class="preview-container">
								<div id="colorPreview" class="color-preview"></div>
								<div id="text-area-colorPreview"></div>
							</div>
						</div>
					</div>

					<div class="col-lg-4 d-flex align-items-center">
						<div class="flex-column">
							<h3 class="text-muted fw-bolder mt-5 mb-5 ml-2 text-center"> Cor da Font (Letras)</h3>
							<h5 class="text-muted fw-bolder mt-5 mb-5 ml-2 text-center"> Escolha a cor que deseja para a
								font(letras) da pesquisa.</h5>
							<div class="picker-container">
								<div class="label">COR</div>
								<div id="picker2"></div>
								<div class="label">LUMINOSIDADE</div>
							</div>
						</div>
						<div class="flex-row">
							<label class="label">Cor Escolhida:</label>
							<div class="preview-container">
								<div id="colorPreview2" class="color-preview"></div>
								<div id="text-area-colorPreview2"></div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</div>
	</div>
	

	<div id="anchor_container" class="container-xxl mt-6">
		<div class="card-header border-0 pt-6">
			<!--begin::Card title-->
			<h1 class="text-muted fw-bolder mt-5 mb-5 ml-2"> Definindo Árvore </h1>
			<h3 class="text-muted fw-bolder mt-5 mb-5 ml-2"> Defina a avaliação que será o corte entre a Árvore Positiva
				ou Negativa. </h3>


			<!-- abaixo -->


			<div class="card-body pt-0 mt-12">
				<div class="row align-items-center justify-content-center" id="svg-container">
					<div class="col-lg-2">
						<div class="svg-container">
							<label class="svg-label-green d-none" for="svg-2">POSITIVA</label>
							<label class="svg-label-red d-none" for="svg-2">NEGATIVA</label>
							<img id="svg-1" class="svg-nps cursor-pointer" src="\assets\media\svg\nps\very-bad.svg"
								alt="SVG Image">
						</div>
					</div>
					<div class="col-lg-2">
						<div class="svg-container">
							<label class="svg-label-green d-none" for="svg-1">POSITIVA</label>
							<label class="svg-label-red d-none" for="svg-1">NEGATIVA</label>
							<img id="svg-2" class="svg-nps cursor-pointer" src="\assets\media\svg\nps\bad.svg"
								alt="SVG Image">
						</div>
					</div>
					<div class="col-lg-2">
						<div class="svg-container">
							<label class="svg-label-green d-none" for="svg-3">POSITIVA</label>
							<label class="svg-label-red d-none" for="svg-3">NEGATIVA</label>
							<img id="svg-3" class="svg-nps cursor-pointer" src="\assets\media\svg\nps\indifferent.svg"
								alt="SVG Image">
						</div>
					</div>
					<div class="col-lg-2">
						<div class="svg-container">
							<label class="svg-label-green d-none" for="svg-4">POSITIVA</label>
							<label class="svg-label-red d-none" for="svg-4">NEGATIVA</label>
							<img id="svg-4" class="svg-nps cursor-pointer" src="\assets\media\svg\nps\good.svg"
								alt="SVG Image">
						</div>
					</div>
					<div class="col-lg-2">
						<div class="svg-container">
							<label class="svg-label-green d-none" for="svg-5">POSITIVA</label>
							<label class="svg-label-red d-none" for="svg-5">NEGATIVA</label>
							<img id="svg-5" class="svg-nps cursor-pointer" src="\assets\media\svg\nps\great.svg"
								alt="SVG Image">
						</div>
					</div>
				</div>
			</div>




			<!-- acima -->



		</div>
	</div>

</div>


